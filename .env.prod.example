# This file should NEVER be committed to git

# API Configuration
SECRET_KEY=CHANGE_THIS_TO_SECURE_RANDOM_KEY_USE_python_-c_import_secrets_print_secrets.token_urlsafe_32
ALGORITHM=HS256
ENVIRONMENT=production
DEBUG=False
API_PORT=8000
API_HOST=0.0.0.0

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://ridejusto:CHANGE_DB_PASSWORD@db:5432/ridejusto_db
POSTGRES_USER=ridejusto
POSTGRES_PASSWORD=CHANGE_THIS_TO_VERY_SECURE_PASSWORD_openssl_rand_-base64_32
POSTGRES_DB=ridejusto_db
POSTGRES_PORT=5432

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_THIS_TOO

# Logging
LOG_LEVEL=info

# Notes:
# 1. Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. Generate DB password: openssl rand -base64 32
# 3. Keep this file private (add to .gitignore - already done)
# 4. Use strong, unique passwords
# 5. Rotate keys regularly in production
